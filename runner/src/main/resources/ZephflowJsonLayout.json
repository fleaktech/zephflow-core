{
  "@timestamp": {
    "$resolver": "timestamp",
    "pattern": {
      "format": "yyyy-MM-dd'T'HH:mm:ss.SSSXXX"
    }
  },
  "message": {
    "$resolver": "message",
    "stringified": true
  },
  "level": {
    "$resolver": "level",
    "field": "name"
  },
  "logger_name": {
    "$resolver": "logger",
    "field": "name"
  },
  "thread_name": {
    "$resolver": "thread",
    "field": "name"
  },
  "stack_trace": {
    "$resolver": "exception",
    "field": "stackTrace",
    "stringified": true
  },
  "task_id": "${sys:task_id:-}",
  "job_id": "${sys:job_id:-}",
  "worker_id": "${sys:worker_id:-}",
  "service": "${sys:service:-zephflow}",
  "source": "task"
}
